{
  "name": "@stekoe/ocl.js",
  "version": "1.5.0-SNAPSHOT",
  "description": "Object Constraint Language parser written in JavaScript.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "npm run clean && npm run test && tsup",
    "clean": "rimraf dist",
    "lint": "eslint lib test",
    "lint:fix": "eslint lib test --fix",
    "typecheck": "tsc --noEmit",
    "prepare:release": "cross-env RUN_SLOW_TESTS=true npm run build",
    "test": "vitest run",
    "test:coverage": "rimraf coverage && vitest run --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/SteKoe/ocl.js.git"
  },
  "author": "Stephan Köninger <ocl.js@stekoe.de>",
  "homepage": "https://github.com/SteKoe/ocl.js#readme",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^4.1.6",
    "cross-env": "^7.0.3",
    "esbuild-plugin-alias": "0.2.1",
    "eslint": "^10.0.0",
    "rimraf": "^6.0.0",
    "semantic-release": "^25.0.3",
    "tsup": "^8.5.1",
    "tsx": "^4.20.3",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^4.1.6"
  }
}
